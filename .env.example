# ============================================================
# BidForge AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# GROQ API (LLM inference — llama-3.3-70b-versatile)
# Get your key at: https://console.groq.com/keys
# ----------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ----------------------------------------------------------
# Supabase (PostgreSQL database)
# Find these in: Supabase Dashboard → Settings → API
# ----------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here

# ----------------------------------------------------------
# Demo / Reliability mode
# Set to true the night before the hackathon after warming cache.
# When true, ALL LLM calls are served from app/data/cache/
# and GROQ is never contacted — safe for live demo.
# ----------------------------------------------------------
DEMO_MODE=false

# ----------------------------------------------------------
# Upload settings
# ----------------------------------------------------------
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# Manual bid-prep baseline in hours for the effort-reduction metric
MANUAL_BASELINE_HOURS=6.0

# Fallback LLM via OpenRouter - used automatically when GROQ is rate-limited
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
