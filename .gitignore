# ============================================================
# BidForge AI — Git Ignore
# ============================================================

# Environment
.env
*.env.local
node_modules/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
venv/
venv_old/
.venv/
env/
.env/

# Uploads (user-submitted RFP files — not for version control)
uploads/

# LLM cache (re-generated by warm_cache.py; exclude for clean repo)
# Comment this line out if you want to commit the pre-warmed cache
app/data/cache/

# FAISS index (rebuilt at startup from capability_library.json)
*.index
*.faiss

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Coverage
.coverage
htmlcov/
.pytest_cache/
